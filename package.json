{
  "name": "folder-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "e2e": "playwright test",
    "preview": "vite preview",
    "package:itch": "pnpm build && cd dist && zip -r ../root-itch.zip .",
    "check": "biome check",
    "check:write": "biome check --write",
    "knip": "knip",
    "dupe": "dupehound scan .",
    "dupe:check": "dupehound check --diff master .",
    "verify": "pnpm check && pnpm knip && pnpm dupe && pnpm test && pnpm build"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.61.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "knip": "^6.17.1",
    "sass": "^1.77.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
